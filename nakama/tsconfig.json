{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./build",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": false,
    "typeRoots": ["./node_modules"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
